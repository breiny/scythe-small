# Database (PostgreSQL + PostGIS via Docker)
DATABASE_URL=postgresql://scythe:scythe@localhost:5432/scythe

# AWS (leave empty for local dev — mock OCR is used automatically)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=scythe-photos
CLOUDFRONT_DOMAIN=

# Auth (JWT-based for local dev, no Cognito required)
COGNITO_USER_POOL_ID=
COGNITO_CLIENT_ID=
JWT_SECRET=scythe-dev-secret-change-me

# OCR + LLM (mock extractor/parser used when AWS keys are empty)
TEXTRACT_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-haiku-20240307-v1:0

# App
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
